{
  "properties": {
    "displayName": "Set Arc SQL Server License Type",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "Detects Azure Arc-enabled SQL Server instances and sets the SQL license type (default Paid) by deploying the WindowsAgent.SqlServer extension. Instances carrying the exclusion tag are skipped.",
    "metadata": {
      "category": "Azure Arc",
      "version": "1.0.0"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "DeployIfNotExists, AuditIfNotExists or Disabled the execution of the Policy"
        },
        "allowedValues": [
          "DeployIfNotExists",
          "AuditIfNotExists",
          "Disabled"
        ],
        "defaultValue": "DeployIfNotExists"
      },
      "licenseType": {
        "type": "String",
        "metadata": {
          "displayName": "SQL License Type",
          "description": "The license type to set on detected Arc-enabled SQL Server instances"
        },
        "allowedValues": [
          "Paid",
          "PAYG",
          "LicenseOnly"
        ],
        "defaultValue": "Paid"
      },
      "exclusionTagName": {
        "type": "String",
        "metadata": {
          "displayName": "Exclusion Tag Name",
          "description": "Name of a tag on the SQL Server instance resource. Instances carrying this tag with the exclusion value are skipped by the policy (not evaluated or remediated)."
        },
        "defaultValue": "ExcludeFromSqlLicensePolicy"
      },
      "exclusionTagValue": {
        "type": "String",
        "metadata": {
          "displayName": "Exclusion Tag Value",
          "description": "Value of the exclusion tag that causes a SQL Server instance to be skipped by the policy."
        },
        "defaultValue": "true"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.AzureArcData/sqlServerInstances"
          },
          {
            "not": {
              "field": "[concat('tags[', parameters('exclusionTagName'), ']')]",
              "equals": "[parameters('exclusionTagValue')]"
            }
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "type": "Microsoft.AzureArcData/sqlServerInstances",
          "name": "[field('name')]",
          "roleDefinitionIds": [
            "/providers/Microsoft.Authorization/roleDefinitions/b24988ac-6180-42a0-ab88-20f7382dd24c"
          ],
          "existenceCondition": {
            "field": "Microsoft.AzureArcData/sqlServerInstances/licenseType",
            "equals": "[parameters('licenseType')]"
          },
          "deployment": {
            "properties": {
              "mode": "incremental",
              "template": {
                "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
                "contentVersion": "1.0.0.0",
                "parameters": {
                  "machineName": {
                    "type": "string"
                  },
                  "location": {
                    "type": "string"
                  },
                  "licenseType": {
                    "type": "string"
                  }
                },
                "resources": [
                  {
                    "type": "Microsoft.HybridCompute/machines/extensions",
                    "apiVersion": "2024-07-10",
                    "name": "[concat(parameters('machineName'), '/WindowsAgent.SqlServer')]",
                    "location": "[parameters('location')]",
                    "properties": {
                      "publisher": "Microsoft.AzureData",
                      "type": "WindowsAgent.SqlServer",
                      "settings": {
                        "LicenseType": "[parameters('licenseType')]",
                        "SqlManagement": {
                          "IsEnabled": true
                        }
                      }
                    }
                  }
                ],
                "outputs": {
                  "policy": {
                    "type": "string",
                    "value": "[concat('Set SQL license type to ', parameters('licenseType'), ' on machine: ', parameters('machineName'))]"
                  }
                }
              },
              "parameters": {
                "machineName": {
                  "value": "[field('name')]"
                },
                "location": {
                  "value": "[field('location')]"
                },
                "licenseType": {
                  "value": "[parameters('licenseType')]"
                }
              }
            }
          }
        }
      }
    }
  }
}
